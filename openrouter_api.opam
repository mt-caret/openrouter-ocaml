opam-version: "2.0"
synopsis: "OCaml client for the OpenRouter API"
description:
  "An Async-based OCaml client for OpenRouter (https://openrouter.ai), a unified API for LLMs from multiple providers (Anthropic, OpenAI, Google, and others). Covers chat completions (with streaming, tools, plugins, and structured outputs), text embeddings, and model listing."
maintainer: ["Masayuki Takeda <mtakeda@oeconomia.jp>"]
authors: ["Masayuki Takeda <mtakeda@oeconomia.jp>"]
license: "MIT"
tags: ["openrouter" "llm" "ai" "api-client" "async"]
homepage: "https://github.com/mt-caret/openrouter-ocaml"
doc: "https://github.com/mt-caret/openrouter-ocaml"
bug-reports: "https://github.com/mt-caret/openrouter-ocaml/issues"
depends: [
  "dune" {>= "3.22"}
  "ocaml" {>= "5.4.1"}
  "ppx_jsonaf_conv"
  "ppx_jane"
  "async"
  "cohttp-async"
  "async_ssl"
  "core"
  "jsonaf"
  "ocamlformat" {with-dev-setup}
  "ocaml-lsp-server" {with-dev-setup}
  "odoc" {with-doc}
]
build: [
  ["dune" "subst"] {dev}
